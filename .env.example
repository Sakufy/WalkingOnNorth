# 北行之路 · 环境变量
# 复制此文件为 .env.local（开发）和 Vercel 环境变量（生产）

# Database (Turso — LibSQL 云)
# 本地开发：DATABASE_URL="file:local.db"
# 生产部署：DATABASE_URL="libsql://your-db.turso.io" + TURSO_AUTH_TOKEN
DATABASE_URL="file:local.db"
TURSO_AUTH_TOKEN=""

# Auth.js v5
AUTH_SECRET="your-auth-secret-here"

# Resend (邮件)
AUTH_RESEND_KEY=""

# Cloudflare R2 (图片存储)
CLOUDFLARE_R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
CLOUDFLARE_R2_ACCESS_KEY=""
CLOUDFLARE_R2_SECRET_KEY=""
CLOUDFLARE_R2_BUCKET="beixingzhilu-images"
CLOUDFLARE_R2_PUBLIC_URL="https://cdn.yourdomain.com"

# Cloudflare Turnstile
CLOUDFLARE_TURNSTILE_SITE_KEY=""
CLOUDFLARE_TURNSTILE_SECRET_KEY=""

# Umami Analytics
UMAMI_WEBSITE_ID=""
